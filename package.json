    "hyperswarm-local-bootstrap": "hyperdht --bootstrap --host 127.0.0.1 --port 50000",
    "test": "jest --watchAll",
    "postinstall": "patch-package && expo prebuild --clean",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
