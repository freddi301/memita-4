    "web": "expo start --web",
    "lint": "expo lint",
    "build:bare": "tsc -p tsconfig.bare.json && bare-pack --host ios-x86 --host ios-arm --host android-x86 --host android-arm --linked --format bundle.cjs -o ./components/network/bare/bundle.js ./components/network/bare/dist/components/network/bare/index.js && rm -rf ./components/network/bare/dist",
